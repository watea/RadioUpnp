<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorControlHighlight">@color/warm_amber</item>
        <item name="colorAccent">@color/warm_orange</item>
        <item name="colorError">@color/dark_red</item>
        <item name="imageButtonStyle">@style/Widget.AppCompat.Button.Borderless</item>
        <item name="alertDialogTheme">@style/AlertDialogTheme</item>
        <item name="android:textColorHighlight">@color/warm_amber</item>
        <item name="android:textColorPrimaryDisableOnly">@color/warm_amber</item>
        <item name="android:textColorHint">@color/warm_amber</item>
        <item name="android:listDivider">@color/warm_amber</item>
        <item name="mediaRouteTheme">@style/MediaRouterTheme</item>
    </style>

    <style name="AppTheme.Dark" parent="AppTheme">
        <item name="colorPrimary">@color/dark_brown</item>
        <item name="colorPrimaryDark">@color/dark_brown</item>
        <item name="android:textColor">@color/warm_beige</item>
        <item name="android:textColorPrimary">@color/warm_beige</item>
        <item name="android:textColorSecondary">@color/warm_beige</item>
        <item name="android:colorAccent">@color/warm_amber</item>
        <item name="android:windowBackground">@color/black</item>
    </style>

    <style name="AppTheme.Light" parent="AppTheme">
        <item name="colorPrimary">@color/warm_orange</item>
        <item name="colorPrimaryDark">@color/warm_orange</item>
        <item name="android:textColor">@color/dark_brown</item>
        <item name="android:textColorPrimary">@color/dark_brown</item>
        <item name="android:textColorSecondary">@color/dark_brown</item>
        <item name="android:colorAccent">@color/dark_brown</item>
        <item name="android:windowBackground">@color/warm_beige</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.DayNight.ActionBar">
        <item name="colorButtonNormal">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
    </style>

    <style name="SpinnerTheme" parent="@android:style/Widget.Holo.DropDownItem.Spinner">
        <item name="android:textSize">30sp</item>
        <item name="android:textColor">@color/warm_amber</item>
        <item name="android:popupBackground">@color/dark_brown</item>
    </style>

    <style name="MediaRouterTheme" parent="Theme.MediaRouter">
        <item name="android:colorBackground">@color/dark_brown</item>
        <item name="android:textColor">@color/warm_beige</item>
        <item name="android:textColorPrimary">@color/warm_beige</item>
        <item name="android:textColorSecondary">@color/warm_amber</item>
    </style>

    <style name="AlertDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="colorControlActivated">@color/warm_orange</item>
        <item name="android:textColor">@color/warm_beige</item>
        <item name="android:textColorPrimary">@color/warm_beige</item>
        <item name="android:textColorHighlight">@color/warm_amber</item>
    </style>

</resources>